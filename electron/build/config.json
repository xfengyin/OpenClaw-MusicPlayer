{
  "appId": "com.openclaw.musicplayer",
  "productName": "OpenClaw Music Player",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "server/server"
  ],
  "mac": {
    "category": "public.app-category.music",
    "target": ["dmg", "zip"]
  },
  "win": {
    "target": ["nsis", "portable"],
    "artifactName": "${productName}-${version}-setup.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Audio;Player"
  },
  "extraResources": [
    {
      "from": "server",
      "to": "server",
      "filter": ["server"]
    }
  ]
}
